# Copy this file to .env for local Docker/development usage.
# Real secrets must stay out of git.

# PostgreSQL used by docker-compose.yml
DB_USER=diary_user
DB_PASSWORD=change-me
DB_NAME=diary_symptoms

# Backend application
DATABASE_URL=postgresql+asyncpg://diary_user:change-me@db:5432/diary_symptoms
APP_NAME=Diary Of Symptoms API
DEBUG=false
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080
API_AI_KEY=
PORT=8000

# Telegram bot
TOKEN=
BACKEND_API_BASE_URL=http://backend:8000
BOT_REQUEST_TIMEOUT=15
BOT_RETRY_ATTEMPTS=2
BOT_RETRY_BACKOFF=0.4
BOT_PROFILE_CACHE_TTL=30

# Frontend build
VITE_API_BASE_URL=http://127.0.0.1:8000
